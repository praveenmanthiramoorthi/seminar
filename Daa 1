#include <stdio.h>
#include <time.h>

int main()
{
    int n, i, x, arr[10000];   // Turbo C safe size
    int r, repeat = 1000;      // repeat search to measure time
    clock_t start, end;
    double time_taken;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
        arr[i] = i + 1;

    printf("Enter element to search: ");
    scanf("%d", &x);

    start = clock();

    for(r = 0; r < repeat; r++)
    {
        for(i = 0; i < n; i++)
        {
            if(arr[i] == x)
                break;
        }
    }

    end = clock();

    if(i == n)
        printf("Element not found\n");
    else
        printf("Element found at index %d\n", i);

    time_taken = ((double)(end - start)) / CLOCKS_PER_SEC;

    printf("Time taken = %f seconds\n", time_taken);

    return 0;
}
